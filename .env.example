# Alethia Environment Variables

# Modal (redeem $250 credits: modal.com/credits code VVN-YQS-E55)
# Required for backend routes that read from the Modal Volume, including /geo,
# when running the local Docker Compose stack.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Modal cost controls. Defaults are intentionally cheap for local/dev deploys:
# no scheduled jobs, no demo fan-out, one container per function/class, and
# rapid scale-to-zero after activity.
ALETHIA_MODAL_CHEAP_MODE=true
ALETHIA_MODAL_ENABLE_SCHEDULES=false
ALETHIA_MODAL_ENABLE_DEMOS=false
ALETHIA_MODAL_ENABLE_RETRIES=false
ALETHIA_MODAL_MAX_CONTAINERS=1
ALETHIA_MODAL_GPU_MAX_CONTAINERS=1
ALETHIA_MODAL_SCALEDOWN_WINDOW_SECONDS=2
ALETHIA_MODAL_GPU_SCALEDOWN_WINDOW_SECONDS=2
ENABLE_CCTV_ANALYSIS=false

# Shared runtime data
# Defaults to the Modal Volume `alethia-data`. Set to `s3` only after the
# object-storage prefix contains the runtime `raw/` and `processed/` trees.
ALEITHIA_SHARED_DATA_BACKEND=modal
ALEITHIA_MODAL_VOLUME_NAME=alethia-data
# ALEITHIA_OBJECT_STORAGE_BUCKET=
# ALEITHIA_OBJECT_STORAGE_PREFIX=runtime
# ALEITHIA_OBJECT_STORAGE_REGION=us-east-2
# ALEITHIA_OBJECT_STORAGE_ENDPOINT_URL=
# ALEITHIA_OBJECT_STORAGE_ACCESS_KEY_ID=
# ALEITHIA_OBJECT_STORAGE_SECRET_ACCESS_KEY=

# News
NEWSAPI_KEY=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Reviews
YELP_API_KEY=
GOOGLE_PLACES_API_KEY=

# Public Data
SOCRATA_APP_TOKEN=

# Census
CENSUS_API_KEY=

# OpenAI (for vision pipeline GPT-4V labeling + chat generation)
OPENAI_API_KEY=
OPENAI_MODEL_SOCIAL_TRENDS=gpt-5
OPENAI_MODEL_VISION_ASSESS=gpt-5-mini
OPENAI_MODEL_COMMAND_SYNTHESIS=gpt-5

# Supermemory (tabled for later)
SUPERMEMORY_API_KEY=
